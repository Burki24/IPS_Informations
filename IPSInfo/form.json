{
    "elements": [
        {
            "type": "Label",
            "label": "IPS_Informations v2.0"
        },
        {
            "type": "IntervalBox",
            "name": "Intervall",
            "caption": "Aktualisierungsintervall"
        },
        {
            "type": "CheckBox",
            "name": "wanipv4",
            "caption": "WAN IPv4-Adresse ermitteln"
        },
        {
            "type": "ExpansionPanel",
            "caption": "Subscription",
            "items": [
                {
                    "type": "Label",
                    "label": "Die Subscription wird automatisch ermittelt. Zugangsdaten werden nur als Fallback verwendet, wenn lokal kein Ablaufdatum gefunden wird."
                },
                {
                    "name": "SymconAccountUser",
                    "type": "ValidationTextBox",
                    "caption": "Benutzername"
                },
                {
                    "name": "SymconAccountPassword",
                    "type": "PasswordTextBox",
                    "caption": "Passwort"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "label": "Aktualisieren",
            "onClick": "IPSInfo_Update($id);"
        }
    ]
}
